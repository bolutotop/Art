// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

// 采用 sqlite 降低运维成本。若使用 MySQL，将 provider 改为 "mysql" 并在 .env 中修改 DATABASE_URL
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 图片资产数据模型
model Image {
  id        String   @id @default(cuid())
  filename  String
  url       String
  size      Int
  createdAt DateTime @default(now())
}